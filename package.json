{
  "name": "unasciiclaw",
  "version": "0.1.2",
  "description": "Convert ASCII art back to images. CLI tool for the OpenClaw ecosystem.",
  "type": "module",
  "bin": {
    "unascii": "dist/index.js",
    "unasciiclaw": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "ascii",
    "image",
    "art",
    "terminal",
    "openclaw"
  ],
  "author": "psandis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/psandis/unasciiclaw.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "commander": "^14.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
